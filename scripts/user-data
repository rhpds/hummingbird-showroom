#cloud-config
write_files:
  - path: /tmp/quarkus.sh
    content: |
      curl -Ls https://sh.jbang.dev | bash -s - trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/
      curl -Ls https://sh.jbang.dev | bash -s - app install --fresh --force quarkus@quarkusio
      export PATH="$HOME/.jbang/bin:$PATH"
      if ! grep -q '.jbang/bin' ~/.bashrc 2>/dev/null; then
        echo 'export PATH="$HOME/.jbang/bin:$PATH"' >> ~/.bashrc
      fi
    permissions: '0755'
  - path: /etc/containers/systemd/pypiserver.container
    content: |
      [Unit]
      Description=PyPi Local service

      [Container]
      Image=docker.io/pypiserver/pypiserver:latest
      ContainerName=pypiserver
      PublishPort=8000:8080
      Volume=/var/pypi-cache:/data/packages:z

      [Service]
      Restart=on-failure

      [Install]
      WantedBy=default.target
    permissions: '0750'

runcmd:
  - mkdir -m 0755 /var/pypi-cache
  - "pip3 download --python-version=3.14 --only-binary=:all: flask -d /var/pypi-cache/"
  - systemctl daemon-reload
  - systemctl start pypiserver
  - curl -LO https://github.com/sigstore/cosign/releases/download/v2.4.1/cosign-linux-amd64 && install -m 755 cosign-linux-amd64 /usr/local/bin/cosign && rm cosign-linux-amd64
  - curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh -s -- -b /usr/local/bin v1.42.2
  - curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh | sh -s -- -b /usr/local/bin v0.109.1
  - mkdir -p /home/rhel/webserver /home/rhel/flask /home/rhel/scanning /home/rhel/fips
  - curl -o /home/rhel/fips/test-fips.py -L https://raw.githubusercontent.com/rhpds/zero-cve-hummingbird-showroom/refs/heads/mod1-review/scripts/test-fips.py
  - chown -R rhel:rhel /home/rhel/webserver /home/rhel/flask /home/rhel/scanning /home/rhel/fips
  - su -c '/tmp/quarkus.sh' -l rhel
  - rm /tmp/quarkus.sh
  - nohup grype db update &

package_upgrade: false

